# Copy this file to .env and fill in your values

# Strava API — create app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=pick_any_random_string_here

# WhatsApp bridge URL (default works for local dev)
BRIDGE_URL=http://localhost:3000

# Set this when deploying to cloud
PUBLIC_URL=
